<?xml version="1.0" encoding="utf-8"?>
<!-- не используется -->

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textStress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Стресс"
        android:textSize="18sp"
        android:padding="20dp"
        android:background="#FFCDD2"
        android:layout_marginTop="30dp"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/textHarmony"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textHarmony"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Спокойствие"
        android:textSize="18sp"
        android:padding="20dp"
        android:background="#C8E6C9"
        android:layout_marginTop="30dp"
        app:layout_constraintHorizontal_weight="2"
        app:layout_constraintLeft_toRightOf="@id/textStress"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnBreathe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Дыхательная практика"
        android:layout_marginTop="60dp"
        app:layout_constraintHorizontal_bias="0.8"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textStress" />

</androidx.constraintlayout.widget.ConstraintLayout>